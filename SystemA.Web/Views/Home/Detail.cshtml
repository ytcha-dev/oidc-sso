@{
    ViewData["Title"] = "Detail";
}

<h2>Detail 頁面 🔒</h2>
<p class="text-muted mb-4">此頁面需要登入才能瀏覽。</p>

<table class="table table-bordered col-md-6">
    <thead class="table-dark">
        <tr>
            <th>Claim Type</th>
            <th>Value</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var claim in User.Claims)
        {
            <tr>
                <td><code>@claim.Type</code></td>
                <td>@claim.Value</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">回首頁</a>
    <a asp-action="Logout" class="btn btn-outline-danger ms-2">登出</a>
</div>