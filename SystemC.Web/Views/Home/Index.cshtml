@{
    ViewData["Title"] = "System C 首頁";
}

<h2>System C 首頁</h2>

@if (User.Identity?.IsAuthenticated == true)
{
    <p class="text-success fw-bold">✅ 已登入：@User.Identity.Name</p>
    <div class="d-flex gap-2 mt-3">
        <a asp-controller="Home" asp-action="Secret" class="btn btn-primary">Secret 頁（需登入）</a>
        <a asp-controller="Sso" asp-action="Status" class="btn btn-outline-secondary">查看 Claims</a>
        <a asp-controller="Sso" asp-action="Logout" class="btn btn-outline-danger">登出</a>
    </div>
}
else
{
    <p class="text-muted">目前尚未登入。</p>
    <a asp-controller="Sso" asp-action="Login" class="btn btn-primary mt-2">SSO 登入</a>
}

<hr class="mt-5" />
<h5>🔗 跨系統 SSO 驗證</h5>
<a href="https://localhost:7275" class="btn btn-outline-primary mt-2" target="_blank">
    前往 System A
</a>
